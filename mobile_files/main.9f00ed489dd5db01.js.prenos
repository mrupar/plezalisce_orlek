nalnostimi, kot na primer: ozna\u010devanje vrste vzpona, navedbo soplezalca_ke ali \u0161tevila ponovitev. "),t.qZA(),t.TgZ(12,"p"),t._uU(13," Spletna stran www.plezanje.net je uspe\u0161no slu\u017eila svojemu namenu celih osemnajst let, kar jo uvr\u0161\u010da med najstarej\u0161e slovenske spletne strani, ki so \u0161e v uporabi. Ta dolga doba pa je prinesla mnoge te\u017eave pri vzdr\u017eevanju delovanja portala, \u0161e posebej v lu\u010di hitrega napredka spletnih tehnologij, kar smo opazili tudi uporabniki, ko je bila spletna stran nekajkrat za kraj\u0161i \u010das nedostopna. "),t.qZA(),t.TgZ(14,"p"),t._uU(15," Te te\u017eave, mnogo novih idej in \u017eelja po izbolj\u0161anju uporabni\u0161ke izku\u0161nje na mobilnih napravah so nas spodbudili, da se lotimo prenove. V prvi fazi smo se osredoto\u010dili na tehnolo\u0161ko posodobitev, prenos vseh podatkov v novo podatkovno bazo in podprtje klju\u010dnih obstoje\u010dih funkcionalnosti. Idej za izbolj\u0161ave in raz\u0161iritve imamo \u0161e veliko, veseli pa bomo tudi vseh va\u0161ih predlogov. Spletna platforma bo seveda \u0161e naprej ostala brezpla\u010dno dostopna in brez oglasov. "),t.qZA(),t.TgZ(16,"p"),t._uU(17," Celotna koda je dostopna na "),t.TgZ(18,"a",3),t._uU(19,"github.com/plezanje-net"),t.qZA(),t._uU(20,", poteku dela pa lahko v \u017eivo sledite na "),t.TgZ(21,"a",4),t._uU(22,"github.com/orgs/plezanje-net/projects/2"),t.qZA(),t._uU(23,". "),t.qZA(),t.TgZ(24,"p"),t._uU(25," Trenutno ekipo programerjev sestavljamo: An\u017ee Dem\u0161ar, Nejc \u0160tebe in Toma\u017e Bevk. "),t.qZA(),t.TgZ(26,"p"),t._uU(27," \u010ce se nam \u017eeli\u0161 pridru\u017eiti, ima\u0161 predlog za spremembo ali opazi\u0161 napako, nam pi\u0161i na "),t.TgZ(28,"a",5),t._uU(29,"info@plezanje.net"),t.qZA(),t._uU(30,". "),t.qZA(),t.qZA(),t.qZA())},directives:[q.a8],styles:[".grade-modifier[_ngcontent-%COMP%]{position:relative;top:7px;height:20px;line-height:5px}.grade-modifier.hard[_ngcontent-%COMP%]{color:#fb2c2c}.grade-modifier.soft[_ngcontent-%COMP%]{color:#4dc700}h2[_ngcontent-%COMP%], h3[_ngcontent-%COMP%]{color:#000000de;padding:0}"]}),n})();const JI=function(){return["/o-plezanje-net"]};let XI=(()=>{class n{constructor(e){this.layoutService=e}ngOnInit(){this.layoutService.$breadcrumbs.next([{name:"Dnevnik sprememb"}])}}return n.\u0275fac=function(e){return new(e||n)(t.Y36(Ze.P))},n.\u0275cmp=t.Xpm({type:n,selectors:[["app-changelog"]],decls:152,vars:2,consts:[[1,"white-back","mt-16"],[1,"container","py-8"],[1,"container","mt-16"],[1,"date"],["href","/navodila/dodajanje-prispevkov","target","_blank","rel","noreferrer noopener"],["src","/assets/changelog/sprememba-tipov-vzponov.png"],["href","https://plezanje.net/storage/IzracunOcen.pdf","target","_blank","rel","noreferrer noopener"],[1,"grade-modifier","hard"],[1,"grade-modifier","soft"],[3,"routerLink"],["href","https://star.plezanje.net","target","_blank","rel","noopener noreferrer nofollow"]],template:function(e,r){1&e&&(t.TgZ(0,"div",0),t.TgZ(1,"div",1),t.TgZ(2,"h1"),t._uU(3,"Dnevnik sprememb"),t.qZA(),t.qZA(),t.qZA(),t.TgZ(4,"div",2),t.TgZ(5,"mat-card"),t.TgZ(6,"div",3),t._uU(7,"16. 10. 2022"),t.qZA(),t.TgZ(8,"h2"),t._uU(9,"Dodajanje fotografij"),t.qZA(),t.TgZ(10,"p"),t._uU(11," Na strani plezali\u0161ca in na strani plezalne smeri je odslej spet mogo\u010de dodajati fotografije. Pojavno okno za dodajanje fotografije prikli\u010de\u0161 s klikom na povezavo "),t.TgZ(12,"i"),t._uU(13,"Dodaj fotografijo"),t.qZA(),t._uU(14,", ki se nahaja v spustnem seznamu, desno od imena plezali\u0161\u010da oz. smeri. "),t.qZA(),t.qZA(),t.TgZ(15,"mat-card"),t.TgZ(16,"div",3),t._uU(17,"3. 7. 2022"),t.qZA(),t.TgZ(18,"h2"),t._uU(19,"Dodajanje prispevkov"),t.qZA(),t.TgZ(20,"p"),t._uU(21," Odslej lahko vsi_e uporabniki_ce v bazo prispevate plezali\u0161\u010da, sektorje in smeri (velja tako za tujino kot za Slovenijo). Tvoje prispevke bo pred objavo moral potrditi nekdo z uredni\u0161tva, svoje vzpone v dodanih smereh pa lahko kljub temu za\u010dne\u0161 bele\u017eiti takoj. "),t.qZA(),t.TgZ(22,"p"),t._uU(23," Postopek dodajanja prispevkov je podrobneje opisan "),t.TgZ(24,"a",4),t._uU(25,"tukaj"),t.qZA(),t._uU(26,". "),t.qZA(),t.qZA(),t.TgZ(27,"mat-card"),t.TgZ(28,"div",3),t._uU(29,"4. 6. 2022"),t.qZA(),t.TgZ(30,"h2"),t._uU(31," \u0160tevilo vzponov, lepota smeri in poljubni stolpci ter razvr\u0161\u010danje in filtriranje smeri v seznamu "),t.qZA(),t.TgZ(32,"p"),t._uU(33,"Na seznam smeri smo dodali naslednje podatke o smereh:"),t.qZA(),t.TgZ(34,"ul"),t.TgZ(35,"li"),t._uU(36,"\u0161tevilo vseh uspe\u0161nih vzponov v smeri,"),t.qZA(),t.TgZ(37,"li"),t._uU(38,"\u0161tevilo vseh poskusov v smeri (uspe\u0161nih in neuspe\u0161nih),"),t.qZA(),t.TgZ(39,"li"),t._uU(40," \u0161tevilo vseh plezalcev, ki so (uspe\u0161no ali neuspe\u0161no) plezali smer, "),t.qZA(),t.TgZ(41,"li"),t._uU(42,"lepota smeri (zvezdice)."),t.qZA(),t.qZA(),t.TgZ(43,"p"),t._uU(44," Stolpce seznama lahko poljubno prika\u017ee\u0161 ali skrije\u0161 tako, da jih ozna\u010di\u0161 ali odzna\u010di\u0161 v spustnem seznamu. "),t.qZA(),t.TgZ(45,"p"),t._uU(46," Seznam smeri lahko razvrsti\u0161 po kateremkoli stolpcu s klikom na ime stolpca (na ve\u010djih zaslonih) ali z izbiro iz spustnega seznama (na manj\u0161ih zaslonih). "),t.qZA(),t.TgZ(47,"p"),t._uU(48," Na ve\u010djih plezali\u0161\u010dih, kjer so seznami smeri dolgi, lahko iskano smer odslej hitro poi\u0161\u010de\u0161 tako, da del imena smeri vnese\u0161 v iskalno polje nad seznamom. "),t.qZA(),t.qZA(),t.TgZ(49,"mat-card"),t.TgZ(50,"div",3),t._uU(51,"12. 5. 2022"),t.qZA(),t.TgZ(52,"h2"),t._uU(53,"Glasovanje o te\u017eavnosti in lepoti smeri"),t.qZA(),t.TgZ(54,"p"),t._uU(55," Mnenje o te\u017eavnosti smeri (predlog ocene) lahko odslej poda\u0161 tudi kadar zabele\u017ei\u0161 vzpon z vidnostjo 'samo zame' ali 'samo za prijatelje'. "),t.qZA(),t.TgZ(56,"p"),t._uU(57," Mnenje o lepoti smeri (zvezdice) lahko odslej poda\u0161 tudi kadar zabele\u017ei\u0161 neuspe\u0161en vzpon v smeri. "),t.qZA(),t.TgZ(58,"p"),t._uU(59," Tvoje mnenje o te\u017eavnosti smeri in tvoje mnenje o lepoti smeri bosta vedno javno objavljena, ne glede na izbrano vidnost zabele\u017eenega vzpona. "),t.qZA(),t.qZA(),t.TgZ(60,"mat-card"),t.TgZ(61,"div",3),t._uU(62,"12. 4. 2022"),t.qZA(),t.TgZ(63,"h2"),t._uU(64,"Preverjanje tipov vzponov"),t.qZA(),t.TgZ(65,"p"),t._uU(66," Kadar v plezalni dnevnik vna\u0161a\u0161 plezalni dan 'za nazaj' se lahko zgodi, da pri vnosu izbere\u0161 tip vzpona, ki ni zdru\u017eljiv s tipi vzponov na vzponih, ki jih ima\u0161 za to smer \u017ee zabele\u017eene v dnevniku. "),t.qZA(),t.TgZ(67,"p"),t._uU(68," Dodali smo avtomatiko, ki v takih primerih kasnej\u0161e tipe vzponov ustrezno spremeni. Pred tem se v pojavnem oknu poka\u017eejo nameravane spremembe, ki jih mora\u0161 potrditi. "),t.qZA(),t.TgZ(69,"p"),t._uU(70," Na primer: Za dan 10. 4. 2022 vna\u0161a\u0161 vzpon v smeri "),t.TgZ(71,"i"),t._uU(72,"Steber"),t.qZA(),t._uU(73," s tipom vzpona 'na pogled'. V dnevniku ima\u0161 na dan 11. 4. 2022 \u017ee zabele\u017een vzpon v smeri "),t.TgZ(74,"i"),t._uU(75,"Steber"),t.qZA(),t._uU(76," in sicer s tipom vzpona 'flash'. Vzpon tipa 'flash' "),t.TgZ(77,"u"),t._uU(78,"za"),t.qZA(),t._uU(79," vzponom tipa 'na pogled' seveda ni mo\u017een zato se ob vnosu prika\u017ee pojavno okno z obvestilom, da se bo vzpon tipa 'flash' avtomatsko spremenil v vzpon tipa 'ponovitev'. "),t.qZA(),t.TgZ(80,"p"),t._UZ(81,"img",5),t.qZA(),t.qZA(),t.TgZ(82,"mat-card"),t.TgZ(83,"div",3),t._uU(84,"26. 3. 2022"),t.qZA(),t.TgZ(85,"h2"),t._uU(86,"Kaj je novega?"),t.qZA(),t.TgZ(87,"h3"),t._uU(88,"Obiskanost po mesecih"),t.qZA(),t.TgZ(89,"p"),t._uU(90," Na stran plezali\u0161\u010da smo dodali graf, ki prikazuje razmerje vne\u0161enih vzponov v tem plezali\u0161\u010du glede na mesec v letu - da bo la\u017eje predvideti, v kateri sezoni se spla\u010da plezali\u0161\u010de obiskati. V prihodnje nameravamo iz teh podatkov pridobiti tudi seznam priporo\u010denih plezali\u0161\u010d za trenutno obdobje na prvi strani in podoben prikaz na nivoju sektorja ali smeri. "),t.qZA(),t.TgZ(91,"h3"),t._uU(92,"Plezalni dnevnik na plezali\u0161\u010dih"),t.qZA(),t.TgZ(93,"p"),t._uU(94," Plezalni dnevnik smo integrirali \u017ee v pogled plezali\u0161\u010da. Pri vsaki smeri se pojavi indikator, ki ponazarja, \u010de si to smer \u017ee kdaj preplezal_a. Preplezane smeri si lahko obkljuka\u0161 kar na seznamu, nato pa jih z gumbom prenese\u0161 v obrazec za vnos v dnevnik. Na njem izbere\u0161 na kak\u0161en na\u010din si preplezal smeri, jim predlaga\u0161 oceno, lepoto in ostale podatke. Z gubom lahko smeri tudi ponovi\u0161, \u010de si jih v istem dnevu preplezal_a ve\u010dkrat. \u010ce vna\u0161a\u0161 smeri za nazaj, jih je mo\u017eno vnesti tudi brez vnosa plezalnega dneva. V tem primeru lahko datum nastavlja\u0161 pri vsaki posamezni smeri v seznamu. "),t.qZA(),t.TgZ(95,"h3"),t._uU(96,"Opozorila"),t.qZA(),t.TgZ(97,"p"),t._uU(98," Na pomembna opozorila, ki se objavljajo na plezali\u0161\u010dih, smo dodali mo\u017enost izpostavljanja na prvi strani s \u010dasovno omejitvijo. Tako bodo pomembna obvestila te\u017eje spregledana. V na\u010drtu imamo \u0161e mo\u017enost arhiviranja opozoril. Opozorilo lahko na plezali\u0161\u010de doda vsak uporabnik, menu za dodajanje je na desni strani vrstice z naslovom plezali\u0161\u010da. "),t.qZA(),t.TgZ(99,"h3"),t._uU(100,"Tipi vzponov"),t.qZA(),t.TgZ(101,"p"),t._uU(102," Dodali smo nov tip vzpona - ponovitev. Kot ponovitev se \u0161teje vsak uspe\u0161en vzpon v smeri, ki si jo pred tem \u017ee preplezal_a na pogled, flash ali z rde\u010do piko. Zaradi konsistenosti baze podatkov, so se tudi obstoje\u010de ponovljene rde\u010de pike spremenile v ponovitve. "),t.qZA(),t.TgZ(103,"h3"),t._uU(104,"Iskalnik"),t.qZA(),t.TgZ(105,"p"),t._uU(106," Na prvo stran smo dodali iskalnik, s katerim lahko hkrati i\u0161\u010de\u0161 po plezali\u0161\u010dih, smereh, sektorjih ali komentarjih. Rezultati iskanja se prikazujejo \u017ee med samim vna\u0161anjem in s klikom nanje lahko tudi presko\u010di\u0161 stran s strukturiranim izpisom zadetkov ter tako \u0161e hitreje prispe\u0161 na ciljno stran. "),t.qZA(),t.TgZ(107,"h3"),t._uU(108,"Moji klubi"),t.qZA(),t.TgZ(109,"p"),t._uU(110," Na stran uporabni\u0161kega profila (dostopna preko glavnega menija, kadar si prijavljen_a) smo dodali podstran Moji klubi. Tu lahko ustvari\u0161 svoj klub in vanj povabi\u0161 druge uporabnike portala plezanje.net. Klubi so pravzaprav skupine, ki omogo\u010dajo deljenje vzponov med \u010dlani iste skupine. Vsi vzponi, ki jih v plezalni dnevnik vnese\u0161 kot Samo za prijatelje bodo vidni vsem \u010dlanom klubov katerih \u010dlan si (ne bodo pa javno objavljeni). Uporabniki starega plezanje.net to sekcijo morda poznate pod imenom Moj ferajn. "),t.qZA(),t.TgZ(111,"h3"),t._uU(112,"Ocenjevanje te\u017eavnosti"),t.qZA(),t.TgZ(113,"p"),t._uU(114," Algoritem za izra\u010dun povpre\u010dne ocene smeri iz glasov uporabnikov je ostal povsem enak kot na starem plezanje.net (razlaga algoritma je dostopna "),t.TgZ(115,"a",6),t._uU(116,"tukaj"),t.qZA(),t._uU(117,"). Nekoliko smo poenostavili le glasovanje o ocenah, in sicer tako, da je odslej mogo\u010de glas podati le v \u201cpolnih\u201d ocenah (npr. 6a, 6a+, 6b...) in ni\u010d ve\u010d v \u201cpolovi\u010dkah\u201d (npr. 6a/a+, 6a+/b, 6b+/c...). "),t.qZA(),t.TgZ(118,"p"),t._uU(119," Ker smo iz stare baze prenesli tudi glasove, ki so bili podani v \u201cpolovi\u010dkah\u201d, se ti v tak\u0161ni obliki \u0161e vedno prikazujejo na seznamu glasov o te\u017eavnosti smeri. Kljub temu, da so vmesne ocene izvzete iz glasovanja, se zavedamo kako pomembno je vedeti katera 7a velja za te\u017eko in katera 6a za lahko, zato smo v teh primerih oceno opremili z dodatno oznako ("),t.TgZ(120,"mat-icon",7),t._uU(121,"arrow_drop_up"),t.qZA(),t._uU(122," te\u017eka, "),t.TgZ(123,"mat-icon",8),t._uU(124,"arrow_drop_down"),t.qZA(),t._uU(125," lahka). "),t.qZA(),t.qZA(),t.TgZ(126,"mat-